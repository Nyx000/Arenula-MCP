<Project>
  <!--
    Auto-injects a ProjectReference for the s&box Base Library so CLI/MSBuild
    builds (dotnet build / dotnet test) can resolve runtime gameplay components
    like NetworkHelper, used by Handlers/NetworkingHandler.cs.

    Why this file exists: arenula_mcp.editor.csproj is auto-generated by s&box
    from sbox_mcp.sbproj on every editor load, so manual ProjectReference edits
    get overwritten. s&box's csproj generator does NOT include Base Library for
    Type:"library" sbprojs (only Type:"game" projects get it via their sibling
    Code csproj). MSBuild auto-includes Directory.Build.targets when building
    via the CLI, but s&box's in-editor compiler ignores this file — so the
    patch only affects CLI builds (where it's needed). Editor compilation
    already resolves Base Library correctly via s&box's own type lookup.

    Override SboxBaseLibraryPath via env var or msbuild property if s&box is
    installed somewhere other than the default Windows Steam location.
  -->
  <PropertyGroup>
    <SboxBaseLibraryPath Condition="'$(SboxBaseLibraryPath)' == ''">C:\Program Files (x86)\Steam\steamapps\common\sbox\addons\base\code\Base Library.csproj</SboxBaseLibraryPath>
  </PropertyGroup>

  <ItemGroup Condition="Exists('$(SboxBaseLibraryPath)')">
    <ProjectReference Include="$(SboxBaseLibraryPath)" />
  </ItemGroup>
</Project>
